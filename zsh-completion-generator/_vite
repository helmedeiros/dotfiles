#compdef vite

# zsh completions for 'vite'
# handcrafted from vite --help output

_vite() {
  local -a commands
  commands=(
    'build:Build for production'
    'optimize:Pre-bundle dependencies'
    'preview:Locally preview production build'
  )

  _arguments \
    '--host[specify hostname]' \
    '--port[specify port]:port' \
    '--open[open browser on startup]' \
    '--cors[enable CORS]' \
    '--strictPort[exit if specified port is already in use]' \
    '--force[force the optimizer to ignore the cache and re-bundle]' \
    '--experimentalBundle[use experimental full bundle mode]' \
    {-c,--config}'[use specified config file]:file:_files' \
    '--base[public base path]:path' \
    {-l,--logLevel}'[log level]:level:(info warn error silent)' \
    '--clearScreen[allow/disable clear screen when logging]' \
    '--configLoader[config loader to use]:loader:(bundle runner native)' \
    {-d,--debug}'[show debug logs]' \
    {-f,--filter}'[filter debug logs]:filter' \
    {-m,--mode}'[set env mode]:mode' \
    {-h,--help}'[display this message]' \
    {-v,--version}'[display version number]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'vite command' commands
      ;;
  esac
}

_vite "$@"
