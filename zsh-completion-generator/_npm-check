  '--no-color[force or disable color output.]'
  '--no-emoji[remove emoji support. No emoji in default in CI environments.]'
  '--debug[debug output. Throw in a gist when creating issues on github.]'
  '*:filename:_files'
)

_arguments -s $arguments
