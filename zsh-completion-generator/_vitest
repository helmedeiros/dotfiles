#compdef vitest

# zsh completions for 'vitest'
# handcrafted from vitest --help output

_vitest() {
  local -a commands
  commands=(
    'run:Run tests once without watch mode'
    'related:Run tests related to changed files'
    'watch:Run tests in watch mode'
    'dev:Run tests in dev mode'
    'bench:Run benchmarks'
    'init:Initialize a project'
    'list:List all tests'
    'complete:Generate shell completions'
  )

  _arguments \
    {-v,--version}'[display version number]' \
    {-r,--root}'[root path]:path:_files -/' \
    {-c,--config}'[path to config file]:path:_files' \
    {-u,--update}'[update snapshot]' \
    {-w,--watch}'[enable watch mode]' \
    {-t,--testNamePattern}'[run tests matching pattern]:pattern' \
    '--dir[base directory to scan for test files]:path:_files -/' \
    '--ui[enable UI]' \
    '--open[open UI automatically]' \
    '--api[specify server port]:port' \
    '--silent[silent console output from tests]' \
    '--hideSkippedTests[hide logs for skipped tests]' \
    '--reporter[specify reporters]:name:(default agent blob verbose dot json tap tap-flat junit tree hanging-process github-actions)' \
    '--outputFile[write test results to a file]:filename:_files' \
    '--coverage[enable coverage report]' \
    '--mode[override Vite mode]:name' \
    '--isolate[run every test file in isolation]' \
    '--globals[inject apis globally]' \
    '--dom[mock browser API with happy-dom]' \
    '--browser[run tests in the browser]:name' \
    '--pool[specify pool]:pool:(forks threads vmForks vmThreads)' \
    '--environment[specify runner environment]:name:(node jsdom happy-dom edge-runtime)' \
    '--passWithNoTests[pass when no tests are found]' \
    '--logHeapUsage[show the size of heap for each test]' \
    '--allowOnly[allow tests marked as only]' \
    '--shard[test suite shard]:shards' \
    '--changed[run tests affected by changed files]' \
    '--inspect[enable Node.js inspector]' \
    '--inspectBrk[enable Node.js inspector and break before test starts]' \
    '--testTimeout[default timeout of a test in milliseconds]:timeout' \
    '--hookTimeout[default hook timeout in milliseconds]:timeout' \
    '--bail[stop test execution after N failures]:number' \
    '--retry[retry the test specific number of times]:times' \
    '--exclude[additional file globs to exclude]:glob' \
    '--expandSnapshotDiff[show full diff when snapshot fails]' \
    '--typecheck[enable typechecking alongside tests]' \
    '--project[the name of the project to run]:name' \
    '--slowTestThreshold[threshold in ms for slow tests]:threshold' \
    '--maxConcurrency[maximum number of concurrent tests]:number' \
    '--run[disable watch mode]' \
    '--no-color[removes colors from the console output]' \
    '--clearScreen[clear terminal screen when re-running tests]' \
    '--standalone[start without running tests]' \
    '--clearCache[delete all Vitest caches]' \
    '--tagsFilter[run only tests with specified tags]:expression' \
    {-h,--help}'[display this message]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'vitest command' commands
      ;;
  esac
}

_vitest "$@"
