*.log
*.sqlite

# Profiling data
default.profraw
*.profraw

# Unusual filenames
-

# Generally include all dotfiles and configuration files
!*.zsh
!*.sh
!*.conf
!*.symlink

# Security - Environment and credential files
*.env
*.env.local
*.env.development
*.env.test
*.env.production
.env.*
!.env.example

# Security - SSH and GPG keys
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
*_ecdsa
*_ecdsa.pub
*.pem
*.key
*.crt
*.p12
*.pfx
id_*
!id_*.pub.example

# Security - API keys and credentials.
#
# Narrow, intent-shaped patterns rather than broad '*secret*' / '*password*'
# substring matches. The broad patterns created false positives for any file
# whose NAME deals with secret-management (e.g. lib/dot-secrets.sh) without
# adding real coverage — actual secret-bearing files almost always carry one
# of the credential-shaped names or extensions below.
*.token
*.secret
*.secrets
secrets.json
secrets.yml
secrets.yaml
secret.env
credentials.json
credentials.yml
credentials.yaml
credential.env
password*.txt
password*.json
.netrc
.aws/credentials
.gcp/credentials.json

# Claude Code per-project local state (machine-specific permissions etc.)
.claude/

# Security - Database files
*.db
*.sqlite3
*.db-journal

# Specific files to ignore (these override the above inclusions)
git/gitconfig.symlink
