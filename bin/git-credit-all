#!/bin/sh
#
# Change the author name and/or email of a single commit.
#
# Usage: git-credit-all [-f] commit-to-change [new-name [new-email]]
#
#     If -f is supplied, run without the freshness check.
#
#     If <new-name> (or <new-email>) is not provided or is empty, the normal
#     user.name (user.email) Git configuration value will be used.
#

set -e

force=''
if test "$1" = "-f"; then
    force='--force'
    shift
fi

die() {
    printf '%s\n' "$@"
    exit 128
}

targ="$(git rev-parse --verify "$1" 2>/dev/null)" || die "$1 is not a commit"

new_name="${2-}"
new_email="${3-}"

# Build the mailmap-style callback for git-filter-repo
# Determine replacement values, falling back to git config
if [ -z "$new_name" ]; then
    new_name="$(git config user.name)"
fi
if [ -z "$new_email" ]; then
    new_email="$(git config user.email)"
fi

# Get the original author info from the target commit
orig_name="$(git log -1 --format='%an' "$targ")"
orig_email="$(git log -1 --format='%ae' "$targ")"

# Use git-filter-repo with a mailmap to rewrite the specific commit
mailmap_file="$(mktemp)"
echo "$new_name <$new_email> $orig_name <$orig_email>" > "$mailmap_file"

git filter-repo $force --mailmap "$mailmap_file" --refs "$targ"..HEAD

rm -f "$mailmap_file"
